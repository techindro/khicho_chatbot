# ─── Khicho.AI Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# App
VITE_APP_NAME=Khicho.AI
VITE_APP_URL=http://localhost:3000

# Image Generation API (Pollinations.AI is free — no key needed)
# To use a paid API like Stability AI or DALL-E, add keys here:
# VITE_STABILITY_API_KEY=your_stability_ai_key
# VITE_OPENAI_API_KEY=your_openai_api_key

# Auth (when you add a real backend)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Firebase (alternative)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=

# Analytics
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# VITE_POSTHOG_KEY=
